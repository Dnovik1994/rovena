# Backend
APP_NAME="FreeCRM Inviter API"
ENVIRONMENT=development
PRODUCTION=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=mysql+pymysql://rovena:rovena@db:3306/rovena
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
TELEGRAM_BOT_TOKEN=
# Telegram API (my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 3proxy
PROXY_CONFIG_PATH=/app/3proxy.cfg
PROXY_BASE_PORT=10000
PROXY_RELOAD_CMD=docker kill --signal=USR1 3proxy

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_TG_INIT_DATA=

# npm registry/proxy overrides (optional)
NPM_REGISTRY=https://registry.npmjs.org/

# Network proxies (optional)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,*.local

# PyPI registry override (optional)
PIP_INDEX_URL=https://pypi.org/simple
