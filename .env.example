# Backend
APP_NAME="FreeCRM Inviter API"
ENVIRONMENT=development
PRODUCTION=true
API_V1_PREFIX=/api/v1

# --- CORS & WEB_BASE_URL ---
# WEB_BASE_URL: the public URL of your Telegram Mini App frontend.
# Production: MUST be set to your real domain. App will refuse to start if empty.
#   The docker-compose.prod.yml overrides this to https://${DOMAIN}, so just set DOMAIN.
# Development: defaults to http://localhost:5173 (Pydantic default).
WEB_BASE_URL=https://kass.freestorms.top

# CORS_ORIGINS: comma-separated or JSON list of allowed origins.
# Production: set to your actual Mini App domain(s). WEB_BASE_URL MUST be included.
#   Wildcard "*" is rejected in production mode.
#   docker-compose.prod.yml overrides this to ["https://${DOMAIN}"].
#   WARNING: leaving localhost here will crash the worker in production
#   (validate_settings() rejects localhost unless DEV_ALLOW_LOCALHOST=true).
# Example: CORS_ORIGINS=["https://kass.freestorms.top","https://web.telegram.org"]
CORS_ORIGINS=["https://kass.freestorms.top"]

# DEV_ALLOW_LOCALHOST: set to true to allow localhost URLs in CORS_ORIGINS/WEB_BASE_URL
# in production mode. Only for staging/debugging — never use in real production.
DEV_ALLOW_LOCALHOST=false

DATABASE_URL=mysql+pymysql://rovena:rovena@db:3306/rovena
MYSQL_DATABASE=rovena
MYSQL_USER=rovena
MYSQL_PASSWORD=rovena
REDIS_URL=redis://redis:6379/0
# WARNING: JWT_SECRET must be at least 16 characters in production.
# Generate one with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=CHANGE-ME-GENERATE-WITH-python-c-import-secrets-print-secrets-token_urlsafe-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
TELEGRAM_BOT_TOKEN=
# TTL for Telegram initData validation (seconds). Replay protection.
# Production: MUST be > 0 (recommended 300). App will refuse to start if <= 0.
# Development: set to 0 to disable TTL check (local dev without Telegram).
TELEGRAM_AUTH_TTL_SECONDS=300
# Telegram API (my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Encryption key for Pyrogram session strings (32-byte hex, base64, or passphrase)
SESSION_ENC_KEY=
# Auth flow OTP TTL in seconds (default 300 = 5 min)
AUTH_FLOW_TTL_SECONDS=300
# Max OTP/password attempts per flow (default 5)
AUTH_FLOW_MAX_ATTEMPTS=5
# Admin bootstrap: Telegram user ID that gets auto-promoted to admin on startup/login.
# Only promotes — never downgrades existing admins. Leave empty to disable.
ADMIN_TELEGRAM_ID=
# Alternative: promote by internal user ID (takes precedence over ADMIN_TELEGRAM_ID).
# ADMIN_USER_ID=
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
UFW_ENABLED=true
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=change-me
CELERY_POOL=solo
CELERY_CONCURRENCY=1

# 3proxy
PROXY_CONFIG_PATH=/app/3proxy-cfg/3proxy.cfg
PROXY_BASE_PORT=10000
PROXY_RELOAD_CMD=docker kill --signal=USR1 3proxy

# Frontend
VITE_API_BASE_URL=/api/v1
VITE_TG_INIT_DATA=

# Traefik / Let's Encrypt
DOMAIN=kass.freestorms.top
LE_EMAIL=your@email.com

# npm registry/proxy overrides (optional)
NPM_REGISTRY=https://registry.npmjs.org/

# Network proxies (optional)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,*.local

# PyPI registry override (optional)
PIP_INDEX_URL=https://pypi.org/simple
